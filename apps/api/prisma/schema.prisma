generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  STUDENT
  LECTURER
  DEPARTMENT_ADMIN
  FACULTY_ADMIN
  INSTITUTION_ADMIN
  SUPER_ADMIN
}

enum Plan {
  FREE
  PRO
  ENTERPRISE
}

enum BillingPeriod {
  MONTHLY
  YEARLY
}

model Institution {
  id        String   @id @default(uuid())
  name      String   @unique
  domain    String   @unique
  logo      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  faculties    Faculty[]
  users        User[]
  subscription Subscription?
}

model Subscription {
  id                 String        @id @default(uuid())
  institutionId      String        @unique
  plan               Plan          @default(FREE)
  billingPeriod      BillingPeriod @default(MONTHLY)
  status             String        @default("active") // active, past_due, cancelled, trial
  trialEndsAt        DateTime?
  currentPeriodStart DateTime      @default(now())
  currentPeriodEnd   DateTime?
  paystackCustomerId String?
  paystackSubId      String?
  maxStudents        Int           @default(500)
  maxLecturers       Int           @default(50)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  institution Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)
}

model Faculty {
  id            String   @id @default(uuid())
  name          String
  institutionId String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  institution Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  departments Department[]
  users       User[]
}

model Department {
  id        String   @id @default(uuid())
  name      String
  facultyId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  faculty   Faculty  @relation(fields: [facultyId], references: [id], onDelete: Cascade)
  courses   Course[]
  users     User[]
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  password      String?
  googleId      String?  @unique
  firstName     String
  lastName      String
  role          Role     @default(STUDENT)
  avatar        String?
  level         Int?

  institutionId String?
  facultyId     String?
  departmentId  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  institution Institution? @relation(fields: [institutionId], references: [id])
  faculty     Faculty?     @relation(fields: [facultyId], references: [id])
  department  Department?  @relation(fields: [departmentId], references: [id])

  enrollments   Enrollment[]
  teaching      Course[]        @relation("CourseLecturer")
  assignments   Assignment[]    @relation("LecturerAssignments")
  submissions   Submission[]
  messages      Message[]
  attendances   Attendance[]
  grades        Grade[]
  markedAttendances Attendance[] @relation("AttendanceMarker")
}

model Course {
  id           String   @id @default(uuid())
  code         String   // e.g., CSC301
  title        String
  description  String?
  level        Int
  credits      Int
  departmentId String
  lecturerId   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  department Department @relation(fields: [departmentId], references: [id])
  lecturer   User?      @relation("CourseLecturer", fields: [lecturerId], references: [id])
  
  enrollments   Enrollment[]
  assignments   Assignment[]
  materials     Resource[]
  announcements Announcement[]
  schedule      Schedule[]
  attendances   Attendance[]
  grades        Grade[]
}

model Enrollment {
  id       String @id @default(uuid())
  userId   String
  courseId String
  progress Float  @default(0)

  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
}

model Assignment {
  id          String   @id @default(uuid())
  title       String
  description String?
  dueDate     DateTime
  courseId    String
  lecturerId  String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lecturer User   @relation("LecturerAssignments", fields: [lecturerId], references: [id])

  submissions Submission[]
}

model Submission {
  id           String   @id @default(uuid())
  content      String?
  fileUrl      String?
  grade        Float?
  feedback     String?
  userId       String
  assignmentId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignment Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)

  @@unique([userId, assignmentId])
}

model Resource {
  id          String   @id @default(uuid())
  title       String
  fileUrl     String
  type        String   // PDF, DOCX, PPTX, VIDEO
  courseId    String
  uploadedBy  String   // userId

  createdAt DateTime @default(now())

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
}

model Announcement {
  id        String   @id @default(uuid())
  title     String
  content   String
  courseId  String?
  target    String   // COURSE, DEPARTMENT, FACULTY, INSTITUTION

  createdAt DateTime @default(now())

  course Course? @relation(fields: [courseId], references: [id], onDelete: Cascade)
}

model Message {
  id        String   @id @default(uuid())
  content   String
  senderId  String
  groupId   String?

  createdAt DateTime @default(now())

  sender User @relation(fields: [senderId], references: [id], onDelete: Cascade)
}

model Attendance {
  id         String   @id @default(uuid())
  userId     String
  courseId   String
  date       DateTime @db.Date
  status     String   @default("absent") // present | absent | late
  markedById String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  markedBy User?  @relation("AttendanceMarker", fields: [markedById], references: [id])

  @@unique([userId, courseId, date])
}

model Schedule {
  id         String   @id @default(uuid())
  courseId   String
  dayOfWeek  Int      // 0=Sunday … 6=Saturday
  startTime  String   // "08:00"
  endTime    String   // "10:00"
  venue      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
}

model Grade {
  id        String   @id @default(uuid())
  userId    String
  courseId  String
  semester  String   // e.g. "2024/2025 First"
  ca        Float    @default(0)
  exam      Float    @default(0)
  total     Float    @default(0)
  grade     String   @default("F")  // A, B, C, D, E, F
  points    Float    @default(0)    // 5.0, 4.0 …

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId, semester])
}
